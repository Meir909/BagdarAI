// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  director
  curator
  student
  parent
}

enum SubscriptionPlan {
  FREE
  PRO
  SCHOOL
}

model User {
  id               String           @id @default(cuid())
  role             Role
  name             String
  email            String?          @unique
  phone            String?          @unique
  passwordHash     String?
  schoolId         String?
  school           School?          @relation(fields: [schoolId], references: [id])
  studentClass     String?
  studentCode      String?          @unique
  subscriptionPlan SubscriptionPlan @default(FREE)
  aiRequestsUsed   Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Curator → Students relationship
  curatorId       String?
  curator         User?   @relation("CuratorStudents", fields: [curatorId], references: [id])
  curatedStudents User[]  @relation("CuratorStudents")

  // Parent → Child relationship
  childId  String? @unique
  child    User?   @relation("ParentChild", fields: [childId], references: [id])
  parentOf User?   @relation("ParentChild")

  careerTests   CareerTest[]
  careerResults CareerResult[]
  chatHistory   ChatMessage[]
  studentBadges StudentBadge[]
  auditLogs     AuditLog[]

  @@index([role])
  @@index([schoolId])
}

model School {
  id             String   @id @default(cuid())
  name           String
  city           String
  schoolCode     String   @unique
  invitationCode String   @unique
  directorPhone  String?
  users          User[]
  createdAt      DateTime @default(now())
}

model CareerTest {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     Json
  completedAt DateTime     @default(now())
  result      CareerResult?

  @@index([userId])
}

model CareerResult {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId             String   @unique
  test               CareerTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  personalitySummary String
  topCareers         Json
  strengths          Json
  skillsToDevelop    Json
  roadmap            Json
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([isActive])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Profession {
  id           String @id @default(cuid())
  name         String
  nameRu       String
  nameKk       String
  category     String
  description  String
  descriptionRu String
  descriptionKk String
  salary       String
  futureDemand Int
  skills       Json
  universities Json   @default("[]")

  @@index([category])
}

model Badge {
  id       String @id @default(cuid())
  name     String
  nameRu   String
  nameKk   String
  icon     String
  trigger  String

  studentBadges StudentBadge[]
}

model StudentBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}
